{{!< default}}

<section class="author-page">
  <header class="author-header">
    <div class="author-header-inner">
      {{#author}}
        {{#if profile_image}}
          <img src="{{img_url profile_image size="m"}}" alt="{{name}}" class="author-page-photo">
        {{/if}}
        <h1 class="author-page-name">{{name}}</h1>
        {{#if bio}}<p class="author-page-bio">{{bio}}</p>{{/if}}
        {{#if location}}<span class="author-page-location">{{location}}</span>{{/if}}
      {{/author}}
    </div>
  </header>

  <div class="section-inner">
    <div class="news-grid">
      {{#foreach posts}}
        {{> post-card}}
      {{/foreach}}
    </div>
    {{pagination}}
  </div>
</section>
