{{#unless @member}}
<section class="cta-section">
  <div class="section-inner">
    <h2>Your Patriot Family<br>Is Waiting</h2>
    <p>Register today to unlock the full alumni directory, post job listings, RSVP to events, and connect with fellow Patriots around the world.</p>
    <div class="cta-buttons">
      <a href="#/portal/signup" class="btn btn-white">Create Your Profile</a>
      <a href="/about" class="btn btn-outline-white">Learn More</a>
    </div>
  </div>
</section>
{{/unless}}

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="{{@site.url}}" class="logo">
          <div>
            <div class="logo-text">DBU</div>
            <div class="logo-sub">Alumni Network</div>
          </div>
        </a>
        <p>Connecting Patriots across the globe to continue the mission of developing Christian servant leaders through a transformative community.</p>
      </div>
      <div class="footer-col">
        <h4>Community</h4>
        <ul>
          <li><a href="/tag/alumni-directory/">Alumni Directory</a></li>
          <li><a href="/tag/chapters/">Chapters</a></li>
          <li><a href="/tag/mentorship/">Mentorship</a></li>
          <li><a href="/tag/class-notes/">Class Notes</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/tag/jobs/">Job Board</a></li>
          <li><a href="/tag/events/">Events</a></li>
          <li><a href="/alumni-benefits/">Alumni Benefits</a></li>
          <li><a href="/transcripts/">Transcripts</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Get Involved</h4>
        <ul>
          <li><a href="https://www.dbu.edu/give" target="_blank" rel="noopener">Give to DBU</a></li>
          <li><a href="/volunteer/">Volunteer</a></li>
          <li><a href="/refer/">Refer a Student</a></li>
          <li><a href="/host/">Host an Event</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {{date format="YYYY"}} Dallas Baptist University. All rights reserved.</span>
      <div class="footer-social">
        {{#if @site.facebook}}
          <a href="{{facebook_url @site.facebook}}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {{/if}}
        {{#if @site.twitter}}
          <a href="{{twitter_url @site.twitter}}" aria-label="Twitter" target="_blank" rel="noopener">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {{/if}}
      </div>
    </div>
  </div>
</footer>
