<article class="event-card">
  <div class="event-banner"></div>
  <a href="{{url}}" class="event-body">
    <div class="event-date">
      <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      {{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{date format="MMM D, YYYY"}}{{/if}}
    </div>
    <h3>{{title}}</h3>
    <p>{{excerpt words="20"}}</p>
    <div class="event-meta">
      {{#foreach tags}}
        {{#unless @first}}
          <span><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> {{name}}</span>
        {{/unless}}
      {{/foreach}}
    </div>
  </a>
</article>
