<article class="post-card {{post_class}}">
  {{#if feature_image}}
    <a href="{{url}}" class="post-card-image" style="background-image: url({{img_url feature_image size="m"}})"></a>
  {{/if}}
  <div class="post-card-body">
    {{#if primary_tag}}
      <a href="{{primary_tag.url}}" class="post-card-tag">{{primary_tag.name}}</a>
    {{/if}}
    <h3 class="post-card-title"><a href="{{url}}">{{title}}</a></h3>
    {{#if custom_excerpt}}
      <p class="post-card-excerpt">{{custom_excerpt}}</p>
    {{else}}
      <p class="post-card-excerpt">{{excerpt words="25"}}</p>
    {{/if}}
    <div class="post-card-meta">
      {{#if primary_author}}
        <span class="post-card-author">{{primary_author.name}}</span>
      {{/if}}
      <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
    </div>
  </div>
</article>
